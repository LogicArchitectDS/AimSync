# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# wrangler / cloudflare workers
.wrangler/
.dev.vars
worker-configuration.d.ts
wrangler.toml.bak

# turbopack / turbo
.turbo/

# eslint cache
.eslintcache

# stylelint cache
.stylelintcache

# parcel
.parcel-cache/
.cache/

# swc
.swc/

# prisma
/prisma/migrations/**/*.sql
!prisma/migrations

# misc tooling caches & state
.cache/
*.log
*.lock.bak

# editors
.vscode/
.idea/

#changes
AimSync Log.txt
